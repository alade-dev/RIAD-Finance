# The address of your deployed RIADFinancePayroll contract
NEXT_PUBLIC_PAYROLL_CONTRACT_ADDRESS=0x 

# The standard ERC-20 token to use for streams (defaults to Arbitrum Sepolia USDC)
NEXT_PUBLIC_USDC_ADDRESS=0x75faf114eafb1BDbe2F0316DF893fd58CE46AA4d

# RPC endpoint for the Next.js API/Viem backend client
ARBITRUM_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc

# =========================================================================
# Database (MongoDB) Configuration
# =========================================================================
# The MongoDB connection string
MONGODB_URI=your_mongodb_connection_uri
MONGODB_DB=riadfinance

# =========================================================================
# AES Key Encryption (Key Vault Security)
# =========================================================================
# 32-byte hexadecimal key used to encrypt/decrypt company private keys at rest
# Run `openssl rand -hex 32` to generate a secure one.
COMPANY_KEY_ENCRYPTION_SECRET=your_32_byte_hex_key
RIADFINANCE_SESSION_SECRET=your_session_secret_key

# Reown Project ID (formerly WalletConnect) for RainbowKit
NEXT_PUBLIC_REOWN_PROJECT_ID=your_reown_project_id
