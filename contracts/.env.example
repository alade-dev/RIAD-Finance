# Deployment Configuration for RIAD Finance Contracts

# Private key for contract deployment (never commit this!)
PRIVATE_KEY=0x

# RPC URLs for different networks
ARBITRUM_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
ARBITRUM_ONE_RPC_URL=https://arb1.arbitrum.io/rpc
ROBINHOOD_CHAIN_RPC_URL=https://chain-rpc.robinhood.com/rpc

# Etherscan-compatible block explorers for verification
ARBITRUM_SEPOLIA_ETHERSCAN_KEY=
ARBITRUM_ONE_ETHERSCAN_KEY=
ROBINHOOD_CHAIN_ETHERSCAN_KEY=

# Contract deployment parameters
OWNER_ADDRESS=0x
INITIAL_TREASURY_ADDRESS=0x

# Token addresses (populate after mainnet deployment)
USDC_ADDRESS=0x
WETH_ADDRESS=0x

# Sablier   Router (will vary by network)
SABLIER_ROUTER_ADDRESS=0x
SABLIER_LOCKUP_LINEAR=0xe4E4ecC586A79aAeAb423B2C6da8F7510de811c5

# Fhenix configuration
FHENIX_GATEWAY_URL=https://gateway.fhenix.zone
FHENIX_ENCRYPTION_KEY=

# Dune API (optional, for indexing verification)
DUNE_API_KEY=
